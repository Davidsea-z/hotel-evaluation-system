            </div>

        </div>
    </section>

    <!-- 酒店项目评估系统 -->
    <section id="project-evaluation" class="section section-dark" aria-label="项目评估系统">
        <div class="section-container">
            
            <!-- 标题区 -->
            <div class="evaluation-header">
                <div class="section-label">PROJECT EVALUATION · 酒店电竞化改造评估</div>
                <h2 class="section-title">项目投资价值评估系统</h2>
                <p class="section-description">输入酒店项目核心指标，AI智能评估投资价值与回报预期</p>
            </div>

            <!-- 评估表单 -->
            <div class="evaluation-form-card">
                <div class="evaluation-form-grid">
                    
                    <!-- 左侧：基础信息 -->
                    <div class="form-section">
                        <h3 class="form-section-title">
                            <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                                <polyline points="9 22 9 12 15 12 15 22"/>
                            </svg>
                            基础信息
                        </h3>
                        
                        <div class="form-group">
                            <label for="projectName">项目名称</label>
                            <input type="text" id="projectName" placeholder="例如：杭州西湖区XX酒店" />
                        </div>
                        
                        <div class="form-group">
                            <label for="projectLocation">项目位置</label>
                            <select id="projectLocation">
                                <option value="">请选择区域类型</option>
                                <option value="core">核心商圈（市中心、CBD）</option>
                                <option value="development">城市开发区（产业园、新区）</option>
                                <option value="integration">产城融合区（大学城、科技城）</option>
                                <option value="scenic">景区周边（旅游热点）</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label for="hotelType">酒店类型</label>
                            <select id="hotelType">
                                <option value="">请选择酒店类型</option>
                                <option value="chain">连锁品牌酒店</option>
                                <option value="independent">独立酒店</option>
                                <option value="boutique">精品民宿</option>
                                <option value="business">商务酒店</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label for="totalRooms">总房间数</label>
                            <input type="number" id="totalRooms" placeholder="例如：30" min="10" max="200" />
                        </div>
                        
                        <div class="form-group">
                            <label for="renovationRooms">计划改造房间数</label>
                            <input type="number" id="renovationRooms" placeholder="例如：20" min="5" max="200" />
                        </div>
                    </div>

                    <!-- 中间：改造前数据 -->
                    <div class="form-section">
                        <h3 class="form-section-title">
                            <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="18" y1="20" x2="18" y2="10"/>
                                <line x1="12" y1="20" x2="12" y2="4"/>
                                <line x1="6" y1="20" x2="6" y2="14"/>
                            </svg>
                            改造前数据
                        </h3>
                        
                        <div class="form-group">
                            <label for="beforePrice">改造前平均房价（元/晚）</label>
                            <input type="number" id="beforePrice" placeholder="例如：200" min="50" max="1000" />
                        </div>
                        
                        <div class="form-group">
                            <label for="beforeOccupancy">改造前平均入住率（%）</label>
                            <input type="number" id="beforeOccupancy" placeholder="例如：60" min="0" max="100" />
                        </div>
                        
                        <div class="form-group">
                            <label for="beforeRevenue">改造前月营收（万元）</label>
                            <input type="number" id="beforeRevenue" placeholder="例如：10" min="0" step="0.1" />
                        </div>
                    </div>

                    <!-- 右侧：改造计划 -->
                    <div class="form-section">
                        <h3 class="form-section-title">
                            <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                            </svg>
                            改造计划
                        </h3>
                        
                        <div class="form-group">
                            <label for="renovationBudget">改造总预算（万元）</label>
                            <input type="number" id="renovationBudget" placeholder="例如：60" min="10" max="500" />
                        </div>
                        
                        <div class="form-group">
                            <label for="equipmentRatio">电竞设备占比（%）</label>
                            <input type="number" id="equipmentRatio" placeholder="建议：75%" min="50" max="90" />
                        </div>
                        
                        <div class="form-group">
                            <label for="targetPrice">目标房价（元/晚）</label>
                            <input type="number" id="targetPrice" placeholder="例如：300" min="100" max="1500" />
                        </div>
                        
                        <div class="form-group">
                            <label for="targetOccupancy">预期入住率（%）</label>
                            <input type="number" id="targetOccupancy" placeholder="建议：85%" min="60" max="100" />
                        </div>
                        
                        <div class="form-group">
                            <label for="gpuLevel">改造方案定位</label>
                            <select id="gpuLevel">
                                <option value="">请选择方案定位</option>
                                <option value="high">旗舰版（RTX5070及以上 | 单房3.5万+）</option>
                                <option value="mid">标准版（RTX5060Ti/5070 | 单房2.5-3.5万）</option>
                                <option value="entry">经济版（RTX5060 | 单房2万-2.5万）</option>
                            </select>
                        </div>
                    </div>

                </div>

                <!-- 评估按钮 -->
                <div class="evaluation-actions">
                    <button id="evaluateBtn" class="btn-evaluate">
                        <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="9 11 12 14 22 4"/>
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                        </svg>
                        开始评估项目
                    </button>
                    <button id="resetBtn" class="btn-reset">
                        <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="1 4 1 10 7 10"/>
                            <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
                        </svg>
                        重置表单
                    </button>
                </div>
            </div>

            <!-- 评估结果区 -->
            <div id="evaluationResults" class="evaluation-results" style="display: none;">
                
                <!-- 综合评分 -->
                <div class="overall-score-card">
                    <div class="score-header">
                        <h3>综合投资价值评分</h3>
                        <p class="score-subtitle">基于多维度指标智能评估</p>
                    </div>
                    <div class="score-display">
                        <div class="score-circle">
                            <svg class="score-ring" viewBox="0 0 100 100">
                                <circle class="score-ring-bg" cx="50" cy="50" r="40"/>
                                <circle id="scoreRingProgress" class="score-ring-progress" cx="50" cy="50" r="40"/>
                            </svg>
                            <div class="score-value-container">
                                <span id="overallScore" class="score-value">0</span>
                                <span class="score-max">/100</span>
                            </div>
                        </div>
                        <div id="scoreLevel" class="score-level">评估中...</div>
                        <div id="scoreDescription" class="score-description"></div>
                    </div>
                </div>

                <!-- 详细指标 -->
                <div class="metrics-grid">
                    
                    <!-- 财务指标 -->
                    <div class="metric-card">
                        <div class="metric-header">
                            <svg class="metric-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="1" x2="12" y2="23"/>
                                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                            </svg>
                            <h4>财务收益</h4>
                        </div>
                        <div class="metric-score">
                            <span id="financeScore" class="metric-value">0</span>
                            <span class="metric-max">/30分</span>
                        </div>
                        <div class="metric-details">
                            <div class="metric-item">
                                <span class="label">预计年营收：</span>
                                <span id="projectedRevenue" class="value">0万元</span>
                            </div>
                            <div class="metric-item">
                                <span class="label">预计年利润：</span>
                                <span id="projectedProfit" class="value">0万元</span>
                            </div>
                            <div class="metric-item">
                                <span class="label">ROI：</span>
                                <span id="projectedROI" class="value">0%</span>
                            </div>
                        </div>
                    </div>

                    <!-- 市场潜力 -->
                    <div class="metric-card">
                        <div class="metric-header">
                            <svg class="metric-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                                <polyline points="17 6 23 6 23 12"/>
                            </svg>
                            <h4>市场潜力</h4>
                        </div>
                        <div class="metric-score">
                            <span id="marketScore" class="metric-value">0</span>
                            <span class="metric-max">/25分</span>
                        </div>
                        <div class="metric-details">
                            <div class="metric-item">
                                <span class="label">区域评级：</span>
                                <span id="locationRating" class="value">-</span>
                            </div>
                            <div class="metric-item">
                                <span class="label">房价提升潜力：</span>
                                <span id="priceGrowth" class="value">0%</span>
                            </div>
                            <div class="metric-item">
                                <span class="label">入住率提升：</span>
                                <span id="occupancyGrowth" class="value">0%</span>
                            </div>
                        </div>
                    </div>

                    <!-- 回本周期 -->
                    <div class="metric-card">
                        <div class="metric-header">
                            <svg class="metric-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <polyline points="12 6 12 12 16 14"/>
                            </svg>
                            <h4>回本速度</h4>
                        </div>
                        <div class="metric-score">
                            <span id="paybackScore" class="metric-value">0</span>
                            <span class="metric-max">/25分</span>
                        </div>
                        <div class="metric-details">
                            <div class="metric-item">
                                <span class="label">回本周期：</span>
                                <span id="paybackPeriod" class="value">0个月</span>
                            </div>
                            <div class="metric-item">
                                <span class="label">评级：</span>
                                <span id="paybackRating" class="value">-</span>
                            </div>
                        </div>
                    </div>

                    <!-- 风险评估 -->
                    <div class="metric-card">
                        <div class="metric-header">
                            <svg class="metric-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            </svg>
                            <h4>风险控制</h4>
                        </div>
                        <div class="metric-score">
                            <span id="riskScore" class="metric-value">0</span>
                            <span class="metric-max">/20分</span>
                        </div>
                        <div class="metric-details">
                            <div class="metric-item">
                                <span class="label">方案定位：</span>
                                <span id="equipmentRating" class="value">-</span>
                            </div>
                            <div class="metric-item">
                                <span class="label">预算合理性：</span>
                                <span id="budgetRating" class="value">-</span>
                            </div>
                            <div class="metric-item">
                                <span class="label">风险等级：</span>
                                <span id="riskLevel" class="value">-</span>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- 投资建议 -->
                <div class="investment-advice-card">
                    <h3 class="advice-title">
                        <svg class="advice-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                        </svg>
                        投资决策建议
                    </h3>
                    <div id="investmentAdvice" class="advice-content">
                        <div class="advice-section">
                            <h4>综合评价</h4>
                            <p id="adviceOverall">评估中...</p>
                        </div>
                        <div class="advice-section">
                            <h4>优势分析</h4>
                            <ul id="adviceStrengths" class="advice-list"></ul>
                        </div>
                        <div class="advice-section">
                            <h4>风险提示</h4>
                            <ul id="adviceRisks" class="advice-list"></ul>
                        </div>
                        <div class="advice-section">
                            <h4>优化建议</h4>
                            <ul id="adviceOptimization" class="advice-list"></ul>
                        </div>
                    </div>
                </div>

                <!-- 对标案例 -->
                <div class="benchmark-card">
                    <h3 class="benchmark-title">
                        <svg class="benchmark-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="7" height="7"/>
                            <rect x="14" y="3" width="7" height="7"/>
                            <rect x="14" y="14" width="7" height="7"/>
                            <rect x="3" y="14" width="7" height="7"/>
                        </svg>
                        参考对标案例
                    </h3>
                    <div id="benchmarkCases" class="benchmark-grid"></div>
                </div>

            </div>

            <!-- 历史记录部分 -->
            <div class="history-section" id="historySection">
                <div class="history-header">
                    <h2 class="history-title">
                        <svg class="history-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <polyline points="12 6 12 12 16 14"/>
                        </svg>
                        评估历史记录
                    </h2>
                    <div class="history-actions">
                        <button id="clearHistoryBtn" class="btn-secondary">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="3 6 5 6 21 6"/>
                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                            </svg>
                            清空记录
                        </button>
                    </div>
                </div>
                <div id="historyList" class="history-list">
                    <div class="history-empty">
                        <svg class="empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        <p>暂无评估记录</p>
                        <p class="empty-hint">完成项目评估后，记录将自动保存在这里</p>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- 投资评估系统（新模块） -->
    <section id="investment-assessment" class="section section-light" aria-label="项目投资评估系统">
        <div class="section-container">
            
            <!-- 标题区 -->
            <div class="evaluation-header">
                <div class="section-label">INVESTMENT ASSESSMENT · 项目投资价值评估</div>
                <h2 class="section-title">六维度智能评估系统</h2>
                <p class="section-description">填写6大核心字段，AI智能分析项目投资价值与风险</p>
            </div>

            <!-- 评估表单容器 -->
            <div id="assessment-form-container" class="assessment-form-container">
                <form id="investmentAssessmentForm" class="investment-assessment-form">
                    
                    <!-- 字段1: 地理位置 -->
                    <div class="assessment-form-section">
                        <h3 class="assessment-section-title">
                            <span class="section-number">1</span>
                            <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                                <circle cx="12" cy="10" r="3"/>
                            </svg>
                            地理位置
                        </h3>
                        <div class="form-group">
                            <label for="geographic_location">详细描述项目地理位置优势 <span class="required">*</span></label>
                            <textarea 
                                id="geographic_location" 
                                name="geographic_location"
                                rows="4" 
                                placeholder="示例：位于未来科技城核心区，毗邻阿里巴巴西溪园区、杭师大等，产业与高校资源密集，西溪银泰城商圈、杭州西站交通枢纽环绕..."
                                required
                                minlength="10"
                            ></textarea>
                            <small class="form-hint">请至少填写10个字符，包括关键地标、交通配套、产业集聚等信息</small>
                        </div>
                    </div>

                    <!-- 字段2: 核心客流 -->
                    <div class="assessment-form-section">
                        <h3 class="assessment-section-title">
                            <span class="section-number">2</span>
                            <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                <circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                            核心客流
                        </h3>
                        <div class="customer-flow-grid">
                            <div class="form-group">
                                <label for="customer_enterprise">企业年轻员工</label>
                                <textarea 
                                    id="customer_enterprise" 
                                    name="customer_enterprise"
                                    rows="3" 
                                    placeholder="描述周边企业员工构成、消费能力等..."
                                ></textarea>
                            </div>
                            <div class="form-group">
                                <label for="customer_student">高校学生</label>
                                <textarea 
                                    id="customer_student" 
                                    name="customer_student"
                                    rows="3" 
                                    placeholder="描述周边高校学生群体、消费习惯等..."
                                ></textarea>
                            </div>
                            <div class="form-group">
                                <label for="customer_business">商旅与参会客群</label>
                                <textarea 
                                    id="customer_business" 
                                    name="customer_business"
                                    rows="3" 
                                    placeholder="描述商务差旅、会议活动客群情况..."
                                ></textarea>
                            </div>
                        </div>
                        <small class="form-hint">至少填写一项客群信息</small>
                    </div>

                    <!-- 字段3: 竞争格局 -->
                    <div class="assessment-form-section">
                        <h3 class="assessment-section-title">
                            <span class="section-number">3</span>
                            <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                            </svg>
                            竞争格局
                        </h3>
                        <div class="competitive-pattern-grid">
                            <div class="form-group">
                                <label for="competitive_direct">直接竞品（电竞酒店）</label>
                                <textarea 
                                    id="competitive_direct" 
                                    name="competitive_direct"
                                    rows="3" 
                                    placeholder="描述周边电竞酒店情况：数量、距离、竞争态势..."
                                ></textarea>
                            </div>
                            <div class="form-group">
                                <label for="competitive_potential">潜在竞品（高端网咖）</label>
                                <textarea 
                                    id="competitive_potential" 
                                    name="competitive_potential"
                                    rows="3" 
                                    placeholder="描述周边高端网咖、电竞馆等情况..."
                                ></textarea>
                            </div>
                            <div class="form-group">
                                <label for="competitive_substitute">替代娱乐</label>
                                <textarea 
                                    id="competitive_substitute" 
                                    name="competitive_substitute"
                                    rows="3" 
                                    placeholder="描述周边其他娱乐设施：KTV、影院、酒吧等..."
                                ></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- 字段4: 电竞馆分布 -->
                    <div class="assessment-form-section">
                        <h3 class="assessment-section-title">
                            <span class="section-number">4</span>
                            <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                                <line x1="8" y1="21" x2="16" y2="21"/>
                                <line x1="12" y1="17" x2="12" y2="21"/>
                            </svg>
                            电竞馆分布 <span class="required">*</span>
                        </h3>
                        <div class="venue-distribution-grid">
                            <div class="form-group">
                                <label for="venue_1km">1km以内（家）</label>
                                <input 
                                    type="number" 
                                    id="venue_1km" 
                                    name="venue_1km"
                                    min="0" 
                                    value="0"
                                    placeholder="0"
                                    required
                                />
                            </div>
                            <div class="form-group">
                                <label for="venue_2km">1-2km（家）</label>
                                <input 
                                    type="number" 
                                    id="venue_2km" 
                                    name="venue_2km"
                                    min="0" 
                                    value="0"
                                    placeholder="0"
                                    required
                                />
                            </div>
                            <div class="form-group">
                                <label for="venue_3km">2-3km（家）</label>
                                <input 
                                    type="number" 
                                    id="venue_3km" 
                                    name="venue_3km"
                                    min="0" 
                                    value="0"
                                    placeholder="0"
                                    required
                                />
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="venue_remarks">备注说明</label>
                            <textarea 
                                id="venue_remarks" 
                                name="venue_remarks"
                                rows="2" 
                                placeholder="补充说明电竞馆分布特点、规模等..."
                            ></textarea>
                        </div>
                    </div>

                    <!-- 字段5: 电竞酒店分布 -->
                    <div class="assessment-form-section">
                        <h3 class="assessment-section-title">
                            <span class="section-number">5</span>
                            <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                                <polyline points="9 22 9 12 15 12 15 22"/>
                            </svg>
                            电竞酒店分布
                        </h3>
                        <div id="esports-hotels-container">
                            <!-- 动态酒店表单将在这里插入 -->
                        </div>
                        <button type="button" class="btn-add-item" onclick="addEsportsHotel()">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="5" x2="12" y2="19"/>
                                <line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                            添加电竞酒店
                        </button>
                    </div>

                    <!-- 字段6: 同档次商务酒店分布 -->
                    <div class="assessment-form-section">
                        <h3 class="assessment-section-title">
                            <span class="section-number">6</span>
                            <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                                <circle cx="12" cy="10" r="3"/>
                            </svg>
                            同档次商务酒店分布
                        </h3>
                        <div id="business-hotels-container">
                            <!-- 动态酒店表单将在这里插入 -->
                        </div>
                        <button type="button" class="btn-add-item" onclick="addBusinessHotel()">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="5" x2="12" y2="19"/>
                                <line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                            添加商务酒店
                        </button>
                        <div class="form-group" style="margin-top: 1rem;">
                            <label for="business_area_remarks">区域分布备注</label>
                            <textarea 
                                id="business_area_remarks" 
                                name="business_area_remarks"
                                rows="2" 
                                placeholder="描述商务酒店的区域分布特点..."
                            ></textarea>
                        </div>
                    </div>

                    <!-- 提交按钮 -->
                    <div class="form-actions">
                        <button type="button" class="btn-secondary" onclick="resetAssessmentForm()">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="1 4 1 10 7 10"/>
                                <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
                            </svg>
                            重置表单
                        </button>
                        <button type="submit" class="btn-primary" id="submitAssessmentBtn">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                <polyline points="22 4 12 14.01 9 11.01"/>
                            </svg>
                            开始评估
                        </button>
                    </div>

                </form>
            </div>

            <!-- 评估结果展示容器（初始隐藏） -->
            <div id="assessment-result-container" class="assessment-result-container" style="display: none;">
                
                <!-- 返回按钮 -->
                <button class="btn-back" onclick="backToAssessmentForm()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="19" y1="12" x2="5" y2="12"/>
                        <polyline points="12 19 5 12 12 5"/>
                    </svg>
                    返回表单
                </button>

                <!-- 综合得分卡片 -->
                <div class="result-score-card">
                    <div class="score-main">
                        <div class="score-label">综合投资价值得分</div>
                        <div class="score-value" id="comprehensiveScore">0.0</div>
                        <div class="score-level" id="valueLevel">评估中...</div>
                    </div>
                    <div class="score-breakdown">
                        <div class="score-item">
                            <span class="score-item-label">优势维度</span>
                            <span class="score-item-value" id="advantageScore">0.0</span>
                        </div>
                        <div class="score-item">
                            <span class="score-item-label">风险维度</span>
                            <span class="score-item-value" id="riskScore">0.0</span>
                        </div>
                    </div>
                </div>

                <!-- 维度得分详情 -->
                <div class="result-dimensions-grid">
                    <div class="dimension-card">
                        <h4>地理位置</h4>
                        <div class="dimension-score" id="dimScore1">0.0</div>
                    </div>
                    <div class="dimension-card">
                        <h4>核心客流</h4>
                        <div class="dimension-score" id="dimScore2">0.0</div>
                    </div>
                    <div class="dimension-card">
                        <h4>竞争格局</h4>
                        <div class="dimension-score" id="dimScore3">0.0</div>
                    </div>
                    <div class="dimension-card">
                        <h4>电竞馆分布</h4>
                        <div class="dimension-score" id="dimScore4">0.0</div>
                    </div>
                    <div class="dimension-card">
                        <h4>电竞酒店分布</h4>
                        <div class="dimension-score" id="dimScore5">0.0</div>
                    </div>
                    <div class="dimension-card">
                        <h4>商务酒店分布</h4>
                        <div class="dimension-score" id="dimScore6">0.0</div>
                    </div>
                </div>

                <!-- 雷达图 -->
                <div class="result-chart-container">
                    <h3 class="chart-title">维度得分雷达图</h3>
                    <canvas id="radarChart"></canvas>
                </div>

                <!-- 评估结论 -->
                <div class="result-conclusion">
                    <div class="conclusion-section">
                        <h4>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            项目优势
                        </h4>
                        <ul id="strengthsList"></ul>
                    </div>
                    <div class="conclusion-section">
                        <h4>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                                <line x1="12" y1="9" x2="12" y2="13"/>
                                <line x1="12" y1="17" x2="12.01" y2="17"/>
                            </svg>
                            风险提示
                        </h4>
                        <ul id="risksList"></ul>
                    </div>
                    <div class="conclusion-section">
                        <h4>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 20h9"/>
                                <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                            </svg>
                            优化建议
                        </h4>
                        <ul id="suggestionsList"></ul>
                    </div>
                </div>

                <!-- 操作按钮 -->
                <div class="result-actions">
                    <button class="btn-secondary" onclick="backToAssessmentForm()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="1 4 1 10 7 10"/>
                            <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
                        </svg>
                        重新评估
                    </button>
                    <button class="btn-primary" onclick="exportAssessmentReport()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                            <polyline points="7 10 12 15 17 10"/>
                            <line x1="12" y1="15" x2="12" y2="3"/>
                        </svg>
                        导出报告
                    </button>
                </div>

            </div>

        </div>
    </section>

    </main>

    <!-- Back to Top Button -->
    <button id="backToTop" class="back-to-top" aria-label="返回顶部" title="返回顶部">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="18 15 12 9 6 15"/>
        </svg>
    </button>

    <!-- 页脚 -->
    <footer class="footer" role="contentinfo">
        <div class="footer-container">
            <div class="footer-brand">
                <svg class="footer-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                </svg>
                <span>MICROCONNECT AI SLIDES</span>
            </div>
            <p class="footer-text">电竞酒店行业可行性研究报告 · 2026</p>
        </div>
    </footer>

    <script src="js/main.js"></script>
    <script src="js/assessment.js"></script>
</body>
</html>