<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="电竞酒店行业可行性研究报告 2026 - 深度分析市场规模、客群画像、单店财务模型与投资回报，基于毕马威和腾讯电竞权威数据。">
    <meta name="keywords" content="电竞酒店,可行性研究,投资分析,财务模型,电竞产业,酒店业,竞盛酒店,腾讯电竞">
    <meta name="author" content="MICROCONNECT AI">
    <meta name="theme-color" content="#6366f1">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="电竞酒店行业可行性研究报告 2026">
    <meta property="og:description" content="从市场规模、客群画像到单店模型与城市选择 - 深度投资分析报告">
    <meta property="og:site_name" content="MICROCONNECT AI">
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="电竞酒店行业可行性研究报告 2026">
    <meta name="twitter:description" content="从市场规模、客群画像到单店模型与城市选择 - 深度投资分析报告">
    
    <title>电竞酒店行业可行性研究报告 2026 | MICROCONNECT AI</title>
    
    <!-- Preconnect to external resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdn.tailwindcss.com">
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    
    <!-- Stylesheets -->
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/assessment.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Noto+Sans+SC:wght@300;400;500;600;700;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    
    <!-- Scripts with defer for better performance -->
    <script src="https://cdn.tailwindcss.com" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js" defer></script>
    
    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Report",
      "name": "电竞酒店行业可行性研究报告",
      "description": "深度分析电竞酒店市场规模、客群画像、单店财务模型与投资回报",
      "datePublished": "2026-02-03",
      "author": {
        "@type": "Organization",
        "name": "MICROCONNECT AI"
      },
      "publisher": {
        "@type": "Organization",
        "name": "MICROCONNECT AI"
      }
    }
    </script>
</head>
<body>
    <!-- SVG Definitions -->
    <svg style="display: none;">
        <defs>
            <linearGradient id="scoreGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" style="stop-color:#6366f1;stop-opacity:1" />
                <stop offset="100%" style="stop-color:#8b5cf6;stop-opacity:1" />
            </linearGradient>
        </defs>
    </svg>

    <!-- Loading Screen -->
    <div id="loading-screen" class="loading-screen hidden">
        <div class="loading-spinner">
            <div class="spinner"></div>
            <p class="loading-text">加载中...</p>
        </div>
    </div>
    
    <!-- Skip to main content for accessibility -->
    <a href="#main-content" class="skip-to-content">跳转到主内容</a>
    <!-- 导航栏 -->
    <nav class="nav-bar" role="navigation" aria-label="主导航">
        <div class="nav-container">
            <div class="nav-brand">
                <span class="brand-text">MICROCONNECT</span>
            </div>
            <button class="mobile-menu-toggle" aria-label="切换移动菜单" aria-expanded="false">
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
            </button>
            <div class="nav-links" id="navLinks">
                <a href="#hero" class="nav-item">首页</a>
                <a href="#investment-model" class="nav-item">投资模型</a>
                <a href="#project-evaluation" class="nav-item">项目评估</a>
                <a href="#investment-assessment" class="nav-item">投资评估</a>
            </div>
        </div>
    </nav>

    <!-- 英雄区 -->
    <main id="main-content">
    <section id="hero" class="hero-section" aria-label="首页欢迎区">
        <div class="hero-bg"></div>
        
        <!-- 动态光效 -->
        <div class="hero-glow">
            <div class="glow-orb"></div>
            <div class="glow-orb"></div>
            <div class="glow-orb"></div>
        </div>
        
        <!-- 漂浮粒子 -->
        <div class="hero-particles" id="particles"></div>
        
        <div class="hero-container">
            <h1 class="hero-title">
                电竞酒店行业<br>
                <span class="gradient-text">可行性研究报告</span>
            </h1>
            <p class="hero-subtitle">从市场规模、客群画像到单店模型与城市选择</p>
            <div class="hero-meta">
                <div class="meta-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8" y1="2" x2="8" y2="6"/>
                        <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    2026年2月3日
                </div>
                <div class="meta-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
                    </svg>
                    数据驱动决策
                </div>
            </div>
        </div>
        <div class="scroll-indicator">
            <div class="scroll-line"></div>
        </div>
    </section>

    <section id="investment-model" class="section" aria-label="投资模型">
        <div class="section-container">
            <!-- 计算器 -->
            <div class="calculator-section" aria-label="投资计算器">
                <div class="calculator-header">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="4" y="4" width="16" height="16" rx="2"/>
                            <rect x="9" y="9" width="6" height="6"/>
                            <line x1="9" y1="1" x2="9" y2="4"/>
                            <line x1="15" y1="1" x2="15" y2="4"/>
                            <line x1="9" y1="20" x2="9" y2="23"/>
                            <line x1="15" y1="20" x2="15" y2="23"/>
                            <line x1="20" y1="9" x2="23" y2="9"/>
                            <line x1="20" y1="14" x2="23" y2="14"/>
                            <line x1="1" y1="9" x2="4" y2="9"/>
                            <line x1="1" y1="14" x2="4" y2="14"/>
                        </svg>
                        滴灌通投资模型
                    </h3>
                    <button class="reset-btn" onclick="resetCalculator()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="23 4 23 10 17 10"/>
                            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
                        </svg>
                        重置默认值
                    </button>
                </div>

                <div class="calculator-grid">
                    <!-- 第一部分：核心输入估计PCF -->
                    <div class="calc-category">
                        <h4 class="calc-category-title">第一部分：核心输入估计PCF</h4>
                        <div class="calc-inputs">
                            <div class="calc-input-group">
                                <label for="roomCount">房间数量（间）</label>
                                <input type="number" id="roomCount" value="100" min="1" max="999" oninput="calculate()">
                            </div>
                            <div class="calc-input-group">
                                <label for="occupancyRate">入住率（%）</label>
                                <input type="number" id="occupancyRate" value="100" min="0" max="100" step="1" oninput="calculate()">
                            </div>
                            <div class="calc-input-group">
                                <label for="avgPrice">平均房价 ADR（元/间/天）</label>
                                <input type="number" id="avgPrice" value="200" min="50" max="10000" step="10" oninput="calculate()">
                            </div>
                            <div class="calc-input-group">
                                <label for="otaRate">OTA比例（%）</label>
                                <input type="number" id="otaRate" value="9" min="0" max="100" step="0.1" oninput="calculate()">
                            </div>
                            <div class="calc-input-group">
                                <label for="profitShareRate">分成比例（%）</label>
                                <input type="number" id="profitShareRate" value="10" min="0" max="100" step="1" oninput="calculate()">
                            </div>
                        </div>
                        
                        <!-- 酒店核心指标计算结果 -->
                        <div class="calc-result-highlight">
                            <div class="result-item-large">
                                <span class="result-label">RevPAR（每间可售房收益）</span>
                                <div class="result-value-container">
                                    <span class="result-value" id="revparResult">0</span>
                                    <span class="result-unit">元/间/天</span>
                                </div>
                                <span class="result-formula">RevPAR = ADR × OCC × (1 - OTA比例)</span>
                            </div>
                            <div class="result-item-large">
                                <span class="result-label">滴灌通分成预期现金流 PCF</span>
                                <div class="result-value-container">
                                    <span class="result-value highlight" id="pcfResult">0</span>
                                    <span class="result-unit">元/天</span>
                                </div>
                                <span class="result-formula">PCF = 房间数量 × RevPAR × 分成比例</span>
                            </div>
                        </div>
                    </div>

                    <!-- 第二部分：设备投资 -->
                    <div class="calc-category">
                        <h4 class="calc-category-title">第二部分：设备投资</h4>
                        <div class="calc-inputs">
                            <div class="calc-input-group">
                                <label for="equipmentCost">电竞设备投入（万元）</label>
                                <input type="number" id="equipmentCost" value="100" min="0" step="0.1" oninput="calculate()">
                            </div>
                            <div class="calc-input-group">
                                <label for="totalRenovationCost">改造总投入（万元）</label>
                                <input type="number" id="totalRenovationCost" value="150" min="0" step="0.1" oninput="calculate()">
                            </div>
                        </div>
                        
                        <!-- 计算结果展示 -->
                        <div class="calc-result-highlight">
                            <div class="result-item-large">
                                <span class="result-label">电竞占比</span>
                                <div class="result-value-container">
                                    <span class="result-value" id="equipmentRatioDisplay">0</span>
                                    <span class="result-unit">%</span>
                                </div>
                                <span class="result-formula">电竞占比 = 电竞设备投入 ÷ 改造总投入 × 100%</span>
                            </div>
                            <div class="result-item-large">
                                <span class="result-label">总投资额</span>
                                <div class="result-value-container">
                                    <span class="result-value highlight" id="totalInvestment2">0</span>
                                    <span class="result-unit">万元</span>
                                </div>
                                <span class="result-formula">总投资额 = 改造总投入</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 第三部分：投资核心指标计算结果 -->
                <div class="calc-results-section">
                    <h4 class="calc-results-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                            <polyline points="17 6 23 6 23 12"/>
                        </svg>
                        投资核心指标计算结果
                    </h4>
                    
                    <!-- 输入参数 -->
                    <div class="calc-inputs-inline">
                        <div class="calc-input-group">
                            <label for="expectedReturn">预期年收益率 r（%）</label>
                            <input type="number" id="expectedReturn" value="18" min="0" max="100" step="1" oninput="calculate()">
                        </div>
                        <div class="calc-input-group">
                            <label for="irrFrequency">IRR分账频率</label>
                            <select id="irrFrequency" onchange="calculate()">
                                <option value="daily">日分账</option>
                                <option value="weekly">周分账</option>
                                <option value="biweekly">双周分账</option>
                            </select>
                        </div>
                    </div>
                    
                    <!-- 计算结果 -->
                    <div class="results-grid-four">
                        <div class="result-card highlight-card">
                            <div class="result-card-header">
                                <span class="result-card-label">目标回收总额</span>
                            </div>
                            <div class="result-card-body">
                                <div style="display: flex; align-items: baseline;">
                                    <div class="result-value-large" id="targetRecoveryResult">0</div>
                                    <div class="result-unit-small">元</div>
                                </div>
                            </div>
                            <div class="result-card-footer">
                                <span class="result-formula-small">目标回收 = 日PCF × YITO期限</span>
                            </div>
                        </div>
                        
                        <div class="result-card highlight-card">
                            <div class="result-card-header">
                                <span class="result-card-label">YITO期限（按18%年收益率）</span>
                            </div>
                            <div class="result-card-body">
                                <!-- 第一行：显示天数 -->
                                <div style="display: flex; align-items: baseline;">
                                    <div class="result-value-large" id="yitoResult">0</div>
                                    <div class="result-unit-small">天</div>
                                </div>
                                <!-- 第二行：显示月份 -->
                                <div style="display: flex; align-items: baseline; margin-top: 5px;">
                                    <div class="result-unit-small">（<span id="yitoResultMonths">0</span>月）</div>
                                </div>
                            </div>
                            <div class="result-card-footer">
                                <span class="result-formula-small">日PCF × T = 总投资额 × (1 + 日r × T)</span>
                            </div>
                        </div>
                        
                        <div class="result-card">
                            <div class="result-card-header">
                                <span class="result-card-label">ROI（投资回报倍数）</span>
                            </div>
                            <div class="result-card-body">
                                <div style="display: flex; align-items: baseline;">
                                    <div class="result-value-large" id="roiResult">0.00</div>
                                    <div class="result-unit-small">倍</div>
                                </div>
                            </div>
                            <div class="result-card-footer">
                                <span class="result-formula-small">ROI = 目标回收总额 / 总投资额</span>
                            </div>
                        </div>
                        
                        <div class="result-card">
                            <div class="result-card-header">
                                <span class="result-card-label" id="irrLabel">IRR（年化）</span>
                            </div>
                            <div class="result-card-body">
                                <div style="display: flex; align-items: baseline;">
                                    <div class="result-value-large" id="irrResult">0.00</div>
                                    <div class="result-unit-small">%</div>
                                </div>
                            </div>
                            <div class="result-card-footer">
                                <span class="result-formula-small" id="irrFormula">NPV=0的贴现率年化</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 计算结果展示 - 待更新 -->
                <!-- <div class="calc-results" style="display:none;">
                    <h4 class="calc-results-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                            <polyline points="17 6 23 6 23 12"/>
                        </svg>
